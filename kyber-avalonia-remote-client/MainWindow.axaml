<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KyberAvaloniaRemoteClient"
        x:Class="KyberAvaloniaRemoteClient.MainWindow"
        Title="{Binding WindowTitle}"
        Width="1400" Height="720"
        MinWidth="800" MinHeight="480">

    <Grid RowDefinitions="Auto,*,150,Auto">

        <!-- Connection Bar -->
        <Border Grid.Row="0" Padding="8" Background="#1E1E1E">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Width="200" Watermark="Host IP (from server)" Text="{Binding Host}"
                         IsEnabled="{Binding CanConnect}" />
                <TextBox Width="120" Watermark="Username" Text="{Binding Username}"
                         IsEnabled="{Binding CanConnect}" />
                <TextBox Width="120" Watermark="Password" Text="{Binding Password}"
                         PasswordChar="&#x2022;" IsEnabled="{Binding CanConnect}" />
                <Button Content="Connect" Command="{Binding ConnectCommand}"
                        IsVisible="{Binding CanConnect}" />
                <Button Content="Disconnect" Command="{Binding DisconnectCommand}"
                        IsVisible="{Binding IsConnected}" />
                <CheckBox Content="SW Decode" IsChecked="{Binding SoftwareDecode}"
                          IsEnabled="{Binding CanConnect}" VerticalAlignment="Center"
                          Foreground="#CCCCCC" />
            </StackPanel>
        </Border>

        <!-- Video Render Area -->
        <Panel Grid.Row="1" Background="#000000" Name="VideoPanel" ClipToBounds="True">
            <local:NativeVideoHost Name="VideoHost"
                                   ClipToBounds="True" />
            <!-- Transparent overlay to capture input events (VLC steals them otherwise) -->
            <Border Name="InputOverlay"
                    Background="Transparent"
                    Focusable="True"
                    IsHitTestVisible="True" />
        </Panel>

        <!-- Log Panel (bottom, fixed height) -->
        <Border Grid.Row="2" Background="#0D0D0D" BorderBrush="#333333" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*">
                <Border Grid.Column="0" Background="#1A1A1A" Padding="8,4" Width="100">
                    <TextBlock Text="Logs" Foreground="#AAAAAA" FontWeight="SemiBold" VerticalAlignment="Center" />
                </Border>
                <ScrollViewer Grid.Column="1" Name="LogScrollViewer"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Padding="8,4">
                    <TextBlock Text="{Binding LogText}"
                               FontFamily="Consolas,Menlo,monospace"
                               FontSize="11"
                               Foreground="#00FF00"
                               TextWrapping="NoWrap" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Padding="8,4" Background="#1E1E1E">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding StatusText}" Foreground="#CCCCCC" />
                <TextBlock Text="{Binding BitrateText}" Foreground="#999999" />
                <TextBlock Text="{Binding LatencyText}" Foreground="#999999" />
                <TextBlock Text="{Binding FpsText}" Foreground="#999999" />
                <TextBlock Name="VolumeText" Foreground="#999999" />
            </StackPanel>
        </Border>

    </Grid>

</Window>
